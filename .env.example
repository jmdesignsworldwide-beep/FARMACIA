# ─────────────────────────────────────────────────────────────
# JM Farmacia — Variables de entorno
# Copia este archivo a .env.local para desarrollo local.
# En producción se configuran en Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Públicas (seguras en el navegador) — prefijo NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# SOLO servidor — marcar "Sensitive" en Vercel. NUNCA con prefijo NEXT_PUBLIC_.
# NUNCA pegar este valor en chats ni commits.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Dominio interno para mapear usuario -> email (el cliente solo ve usuario + contraseña)
INTERNAL_EMAIL_DOMAIN=jmfarmacia.local
